#!/usr/bin/env python3
"""icn-publish — Publish content to an ICN content server over RNS Links.

Standalone wrapper that delegates to the rns_icn library module.
Also works when installed via `pip install -e .` as the `icn-publish` console script.
"""

import sys
import os

sys.path.insert(0, os.path.join(os.path.dirname(__file__), ".."))

from rns_icn.cli_publish import main

if __name__ == "__main__":
    main()
