[Unit]
Description=RNS Transport + ICN Server
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=root
Group=root
Environment="HOME=/root"
Environment="RNS_CONFIG=/etc/rnsd-icn"
ExecStart=bash /opt/rns-icn/run_rns_icn.sh
Restart=always
RestartSec=5
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
