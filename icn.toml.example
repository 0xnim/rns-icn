# ICN Configuration Example
# Copy to icn.toml and customize

[client]
# Path to client identity file (will be created if doesn't exist)
identity_path = "~/.icn/client_identity"

# Mesh interfaces to use (RNS interface names)
mesh_interfaces = ["UTN Oregon"]

# Known ICN servers to connect to
# destination_hash = 32-char hex RNS destination hash
# identity_path = optional pre-shared identity file for announce injection
[[client.known_peers]]
name = "vps-prod"
destination_hash = "24cb54c7ec86294f0723e1d04015b8aa"
identity_path = "~/.icn/vps_identity"

# Timeouts
connect_timeout = 60.0
fetch_timeout = 30.0
path_request_timeout = 30.0

# Retry configuration (exponential backoff)
max_retries = 5
base_retry_delay = 1.0
max_retry_delay = 30.0

# Security: producer signature verification.
# Origins sign Data with their RNS identity (Ed25519). The client always
# rejects Data whose signature is present but invalid. When require_signature
# is true, it also rejects unsigned Data and Data from producers whose key it
# cannot recall. Default false = verify-if-present (additive rollout).
require_signature = false

# Security: rollback protection. The producer binds a sequence number and a
# signing timestamp into the signed envelope; with reject_rollback true the
# client tracks the highest authenticated (signed_at, sequence) seen per name
# and rejects signed Data that rolls back to an older version (a cache/relay
# replaying stale-but-validly-signed content). Only affects signed Data.
# Default false (additive rollout).
reject_rollback = false

# Security: access control. Capability files (rns_icn.access) grant this client
# read access to a producer's restricted (encrypted) prefixes. Each capability
# is signed by the producer and carries the content key wrapped to this client's
# identity; the client verifies the signature, unwraps the key, and transparently
# decrypts matching Data after fetch. Paths are relative to this config file.
# Default: none.
# capabilities = ["caps/acme-private.cap"]

# Logging
log_level = "INFO"
log_json = false

[server]
# Required: path to server identity file (must exist)
identity_path = "/etc/rns-icn/identity"

# RNS destination identity
app_name = "icn"
aspect = "default"

# Mesh interfaces
mesh_interfaces = ["UTN Oregon"]

# Server role: ORIGIN, CACHE, or PROPAGATION
role = "ORIGIN"

# Access control: per-prefix ACLs. Each rule restricts a name prefix to a set of
# consumer identity hashes. Content published under a restricted prefix is
# encrypted at publish with a key derived from this server's identity + prefix
# (caches still store/relay opaque ciphertext); authorized consumers read it via
# a capability minted with ICNServer.issue_capability. prefix = label path under
# this server's namespace; consumers = 32-char hex consumer identity hashes.
# Omit entirely to keep all content public (no encryption). Example:
# [[server.access_rules]]
# prefix = ["private"]
# consumers = ["11111111111111111111111111111111"]

# Announce settings
announce_interval = 30.0
reannounce_on_link = true

# Content Store
cs_max_entries = 10000
cs_ttl_seconds = 0  # <= 0 means no TTL (infinite); positive = seconds until expiry
cs_path = "~/.icn/content_store.db"
cs_prefix_ttls = { "manifest" = 3600 }  # Per-prefix TTL overrides (seconds)
# Stale-while-revalidate window: seconds past a Data's freshness_period during
# which a stale cache hit is served immediately while a background revalidation
# refreshes it upstream. 0 disables it (cache forwards on staleness instead).
cs_stale_while_revalidate = 0

# Resource transport (RNS.Resource for large content)
resource_threshold = 100000  # bytes, ~100KB

# Known peers for announce table injection (other ICN servers to peer with)
[[server.known_peers]]
name = "peer-1"
destination_hash = "aaaaaaaaaaaaaaaaaaaaaaaaaaaaaaaa"
identity_path = "~/.icn/peer1_identity"

# Logging
log_level = "INFO"
log_json = false

# Optional HTTP API (for browser UI)
http_enabled = false
http_host = "127.0.0.1"
http_port = 8080